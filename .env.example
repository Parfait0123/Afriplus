# ─── Supabase ───────────────────────────────────────────────
# Trouvez ces valeurs dans : Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre-anon-key

# Clé service_role (UNIQUEMENT côté serveur — ne jamais exposer au client)
SUPABASE_SERVICE_ROLE_KEY=votre-service-role-key

# ─── Resend (Newsletter emails) ────────────────────────────
# Créez un compte sur resend.com et créez une API key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# ─── Site ──────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# En production : NEXT_PUBLIC_SITE_URL=https://afripulse.com
